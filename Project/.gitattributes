# Универсальные настройки для всех текстовых файлов
* text=auto

# Явно задаём LF для кода и конфигов (рекомендуется для кросс‑платформенности)
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf

# Для пакетных менеджеров
package.json text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf

# Для документации
*.md text eol=lf